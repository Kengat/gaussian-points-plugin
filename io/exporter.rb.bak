module GaussianPoints
  module IO
    module Exporter

      def self.export_xyz
        model = Sketchup.active_model
        edges = model.active_entities.grep(Sketchup::Edge)
        if edges.empty?
          UI.messagebox("Нет рёбер для экспорта.")
          return
        end

        filename = UI.savepanel("Сохранить .xyz", "", "model.xyz")
        return unless filename
        filename += ".xyz" unless File.extname(filename).downcase == ".xyz"

        # Собираем уникальные вершины
        pts = []
        edges.each do |edge|
          pts << edge.start.position
          pts << edge.end.position
        end
        pts.uniq!

        File.open(filename, "w") do |f|
          pts.each do |p|
            f.puts format("%.6f %.6f %.6f", p.x, p.y, p.z)
          end
        end
        UI.messagebox("Экспортировано #{pts.size} точек в #{File.basename(filename)}")
      end

    end
  end
end
