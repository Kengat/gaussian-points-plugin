require 'fiddle'

# Получаем путь к текущему файлу (fiddle_octree_processor.rb)
script_path = File.expand_path(__FILE__)

# Получаем путь к папке плагина
plugin_dir = File.dirname(script_path)

# Наш DLL лежит в корне плагина, а не в io/
dll_path = File.join(plugin_dir, "..", "OctreeProcessorDLL.dll")

# Проверяем, существует ли DLL
unless File.exist?(dll_path)
  UI.messagebox("Ошибка: DLL не найдена по пути: #{dll_path}")
  raise "Не удалось загрузить OctreeProcessorDLL.dll"
end

# Загружаем DLL
octree_dll = Fiddle.dlopen(dll_path)

# Подключаем функцию optimizePointCloud()
optimize_func = Fiddle::Function.new(
  octree_dll['optimizePointCloud'],
  [],  # Нет аргументов
  Fiddle::TYPE_VOID  # Возвращаемый тип
)

# Вызываем функцию
optimize_func.call
puts "Оптимизация облака точек запущена!"
